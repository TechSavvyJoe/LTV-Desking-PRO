[
  {
    "name": "dealers",
    "type": "base",
    "schema": [
      { "name": "name", "type": "text", "required": true },
      { "name": "code", "type": "text", "required": true },
      { "name": "address", "type": "text" },
      { "name": "city", "type": "text" },
      { "name": "state", "type": "text" },
      { "name": "phone", "type": "text" },
      { "name": "email", "type": "email" },
      { "name": "logo", "type": "file" },
      { "name": "active", "type": "bool" },
      { "name": "settings", "type": "json" }
    ]
  },
  {
    "name": "users",
    "type": "auth",
    "note": "PocketBase's default auth collection extended with app fields (1746999001, 1747800001). PB built-ins (email, password, emailVisibility, verified, avatar, ...) omitted here. `active` is the instant-offboarding switch enforced by the users_guard auth hook; the same hook blocks role/dealer self-escalation and validates dealerCode + system_settings.signupsEnabled on public self-registration.",
    "schema": [
      { "name": "firstName", "type": "text" },
      { "name": "lastName", "type": "text" },
      { "name": "phone", "type": "text" },
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      {
        "name": "role",
        "type": "select",
        "options": { "values": ["sales", "manager", "admin", "superadmin"] }
      },
      { "name": "active", "type": "bool" }
    ]
  },
  {
    "name": "inventory",
    "type": "base",
    "note": "The field_visibility hook strips `unitCost` from API responses unless the requester is manager/admin/superadmin.",
    "schema": [
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      { "name": "vin", "type": "text", "required": true },
      { "name": "stockNumber", "type": "text" },
      { "name": "year", "type": "number", "required": true },
      { "name": "make", "type": "text", "required": true },
      { "name": "model", "type": "text", "required": true },
      { "name": "trim", "type": "text" },
      { "name": "mileage", "type": "number" },
      { "name": "price", "type": "number", "required": true },
      { "name": "unitCost", "type": "number" },
      { "name": "jdPower", "type": "number" },
      { "name": "jdPowerRetail", "type": "number" },
      {
        "name": "status",
        "type": "select",
        "options": { "values": ["available", "pending", "sold", "hold"] }
      },
      { "name": "images", "type": "file" },
      { "name": "notes", "type": "text" }
    ]
  },
  {
    "name": "lender_profiles",
    "type": "base",
    "schema": [
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      { "name": "name", "type": "text", "required": true },
      { "name": "active", "type": "bool" },
      { "name": "tiers", "type": "json", "required": true },
      {
        "name": "bookValueSource",
        "type": "select",
        "options": { "values": ["Trade", "Retail"] }
      },
      { "name": "minIncome", "type": "number" },
      { "name": "maxPti", "type": "number" },
      { "name": "minAmountFinanced", "type": "number" },
      { "name": "maxAmountFinanced", "type": "number" },
      { "name": "notes", "type": "text" },
      { "name": "contactName", "type": "text" },
      { "name": "contactPhone", "type": "text" },
      { "name": "contactEmail", "type": "email" },
      { "name": "website", "type": "url" },
      { "name": "portalUrl", "type": "url" },
      { "name": "generalNotes", "type": "text" },
      { "name": "enrichmentSources", "type": "json" },
      { "name": "reservePct", "type": "number" },
      { "name": "fundingDays", "type": "text" }
    ]
  },
  {
    "name": "saved_deals",
    "type": "base",
    "schema": [
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      {
        "name": "user",
        "type": "relation",
        "options": { "collectionId": "users" }
      },
      {
        "name": "vehicle",
        "type": "relation",
        "options": { "collectionId": "inventory" }
      },
      { "name": "name", "type": "text", "required": true },
      { "name": "customerName", "type": "text" },
      { "name": "salespersonName", "type": "text" },
      { "name": "vehicleData", "type": "json", "required": true },
      { "name": "dealData", "type": "json", "required": true },
      { "name": "customerFilters", "type": "json" },
      { "name": "calculatedData", "type": "json" },
      {
        "name": "status",
        "type": "select",
        "options": {
          "values": ["draft", "pending", "submitted", "approved", "funded", "cancelled", "declined"]
        }
      },
      { "name": "lenderName", "type": "text" },
      { "name": "notes", "type": "text" }
    ]
  },
  {
    "name": "dealer_settings",
    "type": "base",
    "schema": [
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      { "name": "defaultTerm", "type": "number" },
      { "name": "defaultApr", "type": "number" },
      { "name": "defaultState", "type": "text" },
      { "name": "docFee", "type": "number" },
      { "name": "cvrFee", "type": "number" },
      { "name": "defaultStateFees", "type": "number" },
      { "name": "outOfStateTransitFee", "type": "number" },
      { "name": "customTaxRate", "type": "number" },
      { "name": "ltvThresholds", "type": "json" },
      { "name": "vscPrice", "type": "number" },
      { "name": "gapPrice", "type": "number" },
      { "name": "miTradeInCreditCap", "type": "number" }
    ]
  },
  {
    "name": "system_settings",
    "type": "base",
    "note": "Singleton record. listRule + viewRule should be empty (public-readable) so login pages can render the announcement banner. createRule, updateRule, deleteRule should be '@request.auth.role = \"superadmin\"'. `signupsEnabled` is also enforced server-side by the users_guard create hook.",
    "schema": [
      { "name": "supportEmail", "type": "email" },
      { "name": "announcementBanner", "type": "text" },
      { "name": "signupsEnabled", "type": "bool" },
      { "name": "defaultLtvThresholds", "type": "json" },
      { "name": "aiDefaults", "type": "json" }
    ]
  },
  {
    "name": "ai_provider_keys",
    "type": "base",
    "note": "Singleton record holding AI provider API keys. All five rules are '@request.auth.id != \"\" && @request.auth.role = \"superadmin\"' — kept out of the publicly-readable system_settings on purpose. The frontend only ever receives masked keys.",
    "schema": [
      { "name": "openaiApiKey", "type": "text" },
      { "name": "anthropicApiKey", "type": "text" },
      { "name": "geminiApiKey", "type": "text" },
      { "name": "lastTested", "type": "json" }
    ]
  },
  {
    "name": "audit_log",
    "type": "base",
    "note": "Append-only security audit trail (AI key changes). list/view superadmin-only; create is superadmin with @request.body.actor = @request.auth.id (1747700000); update/delete are null.",
    "schema": [
      {
        "name": "actor",
        "type": "relation",
        "options": { "collectionId": "users" }
      },
      { "name": "action", "type": "text", "required": true },
      { "name": "target", "type": "text" },
      { "name": "details", "type": "json" }
    ]
  },
  {
    "name": "deal_events",
    "type": "base",
    "note": "Append-only evidentiary record of customer-facing events (what payment was shown, when, by whom). create: any authenticated same-dealer user (dealer_guard force-stamps `dealer`); list/view: same-dealer admin or superadmin; update/delete: null. Rules asserted by 1747800003.",
    "schema": [
      {
        "name": "dealer",
        "type": "relation",
        "options": { "collectionId": "dealers" }
      },
      {
        "name": "user",
        "type": "relation",
        "options": { "collectionId": "users" }
      },
      { "name": "action", "type": "text", "required": true },
      { "name": "customerName", "type": "text" },
      { "name": "vin", "type": "text" },
      { "name": "snapshot", "type": "json" }
    ]
  }
]
