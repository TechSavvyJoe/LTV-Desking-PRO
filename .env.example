# LTV Desking PRO - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git - it contains sensitive credentials

# ============================================
# PocketBase Backend (Required)
# ============================================

# PocketBase URL - Your backend instance URL
# Development: http://localhost:8090
# Production:  https://ltv-desking-pro-api.fly.dev
VITE_POCKETBASE_URL="http://localhost:8090"

# ============================================
# AI Provider Keys
# ============================================
#
# Production: keys live in your PocketBase backend, edited via the Owner
# Console → Settings → AI Providers tab. They are NOT read from env in prod.
#
# The variables below are only used as a fallback for local development
# so `npm run dev` works without first booting a local PocketBase and
# configuring keys through the UI. In production the AI proxy reads keys
# from PB at request time (see server/ai/keyResolver.ts).
#
# Leave these unset if you want to test the prod flow locally (PB-stored
# keys).
#
# OPENAI_API_KEY="sk-…"
# ANTHROPIC_API_KEY="sk-ant-…"
# GEMINI_API_KEY="AIza…"

# ============================================
# AI Proxy → PocketBase (server-only)
# ============================================
#
# In production these are set on Vercel as Project Environment Variables.
# The serverless functions in /api/ai/* authenticate to PocketBase as a
# _superusers account and read the ai_provider_keys collection.
#
# For local dev, NOT setting these falls back to the OPENAI_/ANTHROPIC_/
# GEMINI_API_KEY env values above.
#
# PB_INTERNAL_URL="https://ltv-desking-pro-api.fly.dev"
# PB_SERVICE_EMAIL="ai-proxy@example.com"
# PB_SERVICE_PASSWORD="…"

# ============================================
# Development Settings (Optional)
# ============================================

# Enable debug logging in development
# VITE_DEBUG="true"

# API request timeout (milliseconds)
# VITE_API_TIMEOUT="30000"
