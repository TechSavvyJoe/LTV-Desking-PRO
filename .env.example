# LTV Desking PRO - Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to git - it contains sensitive API keys

# ============================================
# AI Services (Required for AI lender extraction)
# ============================================

# Google Gemini API Key - Get from: https://makersuite.google.com/app/apikey
# Only the VITE_ prefixed version is needed (Vite exposes it to the browser)
VITE_GEMINI_API_KEY="your-gemini-api-key-here"

# Perplexity AI API Key (optional) - Get from: https://www.perplexity.ai/settings/api
# Used for enhanced lender data research when PDF extraction is incomplete
VITE_PERPLEXITY_API_KEY="your-perplexity-api-key-here"

# ============================================
# PocketBase Backend (Required)
# ============================================

# PocketBase URL - Your backend instance URL
# Development: http://localhost:8090
# Production: https://ltv-desking-pro-api.fly.dev
VITE_POCKETBASE_URL="http://localhost:8090"

# ============================================
# Development Settings (Optional)
# ============================================

# Enable debug logging in development
# VITE_DEBUG="true"

# API request timeout (milliseconds)
# VITE_API_TIMEOUT="30000"
